{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(**/uv.lock)",
      "Read(**/package-lock.json)",
      "Read(**/pnpm-lock.yaml)",
      "Read(frontend/dist/**)",
      "Read(**/node_modules/**)",
      "Read(**/.venv/**)",
      "Read(**/__pycache__/**)"
    ]
  },
  "enabledMcpjsonServers": [
    "code-review-graph"
  ],
  "autoMemoryEnabled": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; repo=$(git rev-parse --show-toplevel 2>/dev/null) && code-review-graph update --skip-flows --repo \"$repo\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; repo=$(git rev-parse --show-toplevel 2>/dev/null) && code-review-graph status --repo \"$repo\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
